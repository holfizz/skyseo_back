generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

//ДЕЛАТЬ ТОЛЬКО МИГРАЦИИ И ДАВАТЬ КОМАНДЫ ТОЛЬКО НА МИГРАЦИИ НИКАКИХ npx pirsma push
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  balance                Int       @default(1000) // Приветственный бонус 1000 баллов
  role                   Role      @default(USER)
  userType               UserType? // Кто вы: маркетолог, SEO, предприниматель, стартапер
  referralSource         String? // Откуда узнал
  referralCode           String?   @unique // Реферальный код пользователя
  referredBy             String? // ID пользователя, который пригласил
  city                   String? // Город пользователя
  isActive               Boolean   @default(true)
  isSuspicious           Boolean   @default(false) // Флаг подозрительной активности
  emailVerified          Boolean   @default(false) // Подтверждение email
  emailVerificationToken String?   @unique // Токен для подтверждения email
  lastLoginIp            String? // Последний IP входа
  registrationIp         String? // IP регистрации
  failedLoginAttempts    Int       @default(0) // Неудачные попытки входа
  lastFailedLogin        DateTime? // Последняя неудачная попытка
  appVersion             String? // Версия приложения пользователя
  weeklyReportEnabled    Boolean   @default(true) // Получать еженедельный отчёт
  aiAnalysesCount        Int       @default(0) // Количество выполненных AI-анализов
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  websites            Website[]
  executions          Execution[]
  payments            Payment[]
  balanceHistory      BalanceHistory[]
  passwordResetTokens PasswordResetToken[]
  captchaEvents       CaptchaEvent[]

  @@index([registrationIp, createdAt])
  @@map("users")
}

model Website {
  id        String   @id @default(uuid())
  userId    String
  name      String
  url       String
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      Task[]
  statistics Statistic[]

  @@index([userId])
  @@map("websites")
}

model Task {
  id               String     @id @default(uuid())
  websiteId        String
  type             TaskType
  keyword          String? // Для поиска
  targetUrl        String? // Точный URL страницы для поиска (если задан — матчим по нему, иначе по домену)
  externalUrl      String? // Для внешних ссылок
  geo              String     @default("Москва") // Город для выполнения
  status           TaskStatus @default(PENDING)
  pointsCost       Int        @default(10) // Стоимость задачи
  priority         Int        @default(0)
  maxYandexVisits  Int        @default(3) // Максимум посещений из Яндекса в сутки
  maxGoogleVisits  Int        @default(3) // Максимум посещений из Google в сутки
  useYandex        Boolean    @default(true) // Использовать Яндекс
  useGoogle        Boolean    @default(true) // Использовать Google
  pagesDepthFrom   Int        @default(3) // Минимальная глубина просмотра страниц
  pagesDepthTo     Int        @default(5) // Максимальная глубина просмотра страниц
  pageDurationFrom Int        @default(60) // Минимальная длительность просмотра страницы (сек)
  pageDurationTo   Int        @default(180) // Максимальная длительность просмотра страницы (сек)
  isActive         Boolean    @default(true)
  keywordStatus    KeywordRestrictionStatus @default(ACTIVE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  assignedAt         DateTime?
  assignedExecutorId String?
  completedAt        DateTime?

  website         Website           @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  executions      Execution[]
  positionHistory PositionHistory[]

  @@index([status, priority])
  @@index([assignedExecutorId])
  @@map("tasks")
}

model Execution {
  id            String          @id @default(uuid())
  taskId        String
  executorId    String
  websiteId     String?
  status        ExecutionStatus @default(IN_PROGRESS)
  pointsEarned  Int             @default(0)
  pointsSpent   Int             @default(0)
  foundInTop    Boolean?
  position      Int?
  yandexFoundInTop Boolean?
  googleFoundInTop Boolean?
  yandexPosition   Int?
  googlePosition   Int?
  failureReason    FailureReason?
  targetVisited     Boolean         @default(false)
  directNavigationUsed Boolean      @default(false)
  completionKind    ExecutionCompletionKind?
  pagesVisited  Int             @default(0)
  duration      Int             @default(0)
  ipAddress     String?
  userAgent     String?
  weekStart     DateTime?
  createdAt     DateTime        @default(now())
  completedAt   DateTime?

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  executor User @relation(fields: [executorId], references: [id], onDelete: Cascade)
  events   ExecutionEvent[]

  @@index([executorId, websiteId, weekStart])
  @@map("executions")
}

model ExecutionEvent {
  id          String   @id @default(uuid())
  executionId String?
  taskId      String?
  executorId  String?
  engine      String?
  type        String
  stage       String
  details     Json?
  createdAt   DateTime @default(now())

  execution Execution? @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@index([taskId, createdAt])
  @@index([executorId, createdAt])
  @@map("execution_events")
}

model CaptchaEvent {
  id        String   @id @default(uuid())
  userId    String
  engine    String   // "yandex" | "google"
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("captcha_events")
}

model Statistic {
  id             String   @id @default(uuid())
  websiteId      String
  keyword        String
  position       Int? // null если ниже топ-50
  inTop1         Int      @default(0)
  inTop2_3       Int      @default(0)
  inTop5         Int      @default(0)
  inTop10        Int      @default(0)
  inTop50        Int      @default(0)
  belowTop50     Int      @default(0)
  totalVisits    Int      @default(0)
  yandexSearches Int      @default(0) // Количество поисков в Яндексе
  googleSearches Int      @default(0) // Количество поисков в Google
  yandexVisits   Int      @default(0) // Количество визитов из Яндекса
  googleVisits   Int      @default(0) // Количество визитов из Google
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([websiteId, keyword, date])
  @@map("statistics")
}

model PositionHistory {
  id             String   @id @default(uuid())
  taskId         String
  yandexPosition Int? // Позиция в Яндексе (null если не найдено)
  googlePosition Int? // Позиция в Google (null если не найдено)
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, date])
  @@map("position_history")
}

model BalanceHistory {
  id          String             @id @default(uuid())
  userId      String
  amount      Int // Положительное или отрицательное
  type        BalanceHistoryType
  description String
  taskId      String?
  createdAt   DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("balance_history")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  amount          Decimal       @db.Decimal(10, 2)
  points          Int
  status          PaymentStatus @default(PENDING)
  provider        String        @default("yookassa")
  externalId      String?       @unique // ID платежа в YooKassa
  confirmationUrl String?
  createdAt       DateTime      @default(now())
  paidAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model AppVersion {
  id           String   @id @default(uuid())
  version      String
  platform     Platform // darwin-arm64, darwin-x64, win32-x64, win32-ia32
  downloadUrl  String
  sha512       String // SHA512 хеш файла в base64
  fileSize     Int // Размер файла в байтах
  releaseNotes String[]
  mandatory    Boolean  @default(false) // Обязательное обновление - блокирует работу старых версий
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([version, platform])
  @@map("app_versions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

enum Role {
  USER
  ADMIN
}

enum UserType {
  MARKETER // Маркетолог
  SEO // SEO специалист
  ENTREPRENEUR // Предприниматель
  STARTUP // Стартапер
}

enum TaskType {
  SEARCH_KEYWORD // Поиск по ключевому слову
  EXTERNAL_LINK // Переход по внешней ссылке
  SEARCH_AND_VISIT // Поиск и посещение сайта
}

enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ExecutionCompletionKind {
  NORMAL
  DEGRADED
  SKIPPED
}

enum BalanceHistoryType {
  WELCOME_BONUS
  TASK_EARNED
  TASK_SPENT
  PAYMENT
  REFUND
  ADMIN_ADJUSTMENT
  REFERRAL_BONUS
}

enum FailureReason {
  CAPTCHA
  SCRIPT_ERROR
  NOT_IN_SERP
  LOCK_TIMEOUT
}

enum KeywordRestrictionStatus {
  ACTIVE
  RESTRICTED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  FAILED
}

enum Platform {
  DARWIN_ARM64 // darwin-arm64
  DARWIN_X64 // darwin-x64
  WIN32_X64 // win32-x64
  WIN32_IA32 // win32-ia32
}
